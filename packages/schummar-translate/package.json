{
  "name": "schummar-translate",
  "version": "0.0.0",
  "description": "TypeScript powered translation library for React and Node.js.",
  "keywords": [
    "IntelliSense",
    "autocomplete",
    "i18n",
    "localization",
    "node",
    "react",
    "translation",
    "type checking",
    "typescript"
  ],
  "license": "MIT",
  "author": {
    "name": "Marco Schumacher",
    "email": "marco@schumacher.dev"
  },
  "repository": "git+https://github.com/schummar/schummar-translate.git",
  "files": [
    "dist",
    "react.js",
    "react.d.ts",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "typesVersions": {
    "*": {
      ".": [
        "dist/index.d.ts"
      ],
      "./react": [
        "dist/react.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@formatjs/icu-messageformat-parser": "^3.5.11",
    "@formatjs/intl-localematcher": "^0.8.10",
    "intl-messageformat": "^11.2.8"
  },
  "devDependencies": {
    "@formatjs/intl-durationformat": "^0.10.15",
    "@js-temporal/polyfill": "0.5.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.0",
    "@types/react": "^19.2.17",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "19.2.7"
  },
  "peerDependencies": {
    "@formatjs/intl-durationformat": ">=0.2.2",
    "@types/react": ">=16.8.0",
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
